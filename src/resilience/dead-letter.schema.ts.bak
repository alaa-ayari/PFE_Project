import { Prop, Schema, SchemaFactory } from '@nestjs/mongoose';
import { Document } from 'mongoose';

/**
 * A write that exhausted all retries. Kept so failed Hedera / FCM / ledger
 * writes are recoverable instead of silently lost (BUG-B10). Operators can
 * inspect or replay these.
 */
@Schema({ timestamps: true })
export class DeadLetter extends Document {
  /** "hedera" | "fcm" | "payment-ledger" */
  @Prop({ type: String, required: true, index: true })
  channel: string;

  /** Everything needed to replay the write. */
  @Prop({ type: Object, required: true })
  payload: Record<string, any>;

  @Prop({ type: String })
  error: string;

  @Prop({ type: Number, default: 0 })
  attempts: number;

  @Prop({ type: Boolean, default: false, index: true })
  replayed: boolean;
}

export const DeadLetterSchema = SchemaFactory.createForClass(DeadLetter);
