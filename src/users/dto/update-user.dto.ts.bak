import { PartialType, OmitType } from '@nestjs/mapped-types';
import { CreateUserDto } from './create-user.dto';

/**
 * Generic user update. `password` and `role` are intentionally omitted:
 *   - password must go through /auth/reset-password (C-01)
 *   - role must never be writable by the user themselves (privilege escalation)
 */
export class UpdateUserDto extends PartialType(
  OmitType(CreateUserDto, ['password', 'role'] as const),
) {}
